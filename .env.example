# Vyakhya Configuration

# Port to run the server on
PORT=8080

# Rate Limiting (per IP)
# Set RATE_LIMIT_RPS=0 to disable rate limiting entirely.
RATE_LIMIT_RPS=10.0
RATE_LIMIT_BURST=20

# Fixed Memory Size Constraints
# MEM_LIMIT_MB sets Go runtime debug.SetMemoryLimit (e.g. 250 MB).
MEM_LIMIT_MB=250

# Go Garbage Collection Percent
# GC_PERCENT sets Go runtime debug.SetGCPercent (e.g. 50% target).
GC_PERCENT=50
